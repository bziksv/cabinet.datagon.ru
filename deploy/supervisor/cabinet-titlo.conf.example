stopwaitsecs=660
stdout_logfile=/var/www/cabinet_titl_usr/data/www/cabinet.titlo.ru/storage/logs/supervisor-cluster-child.log
stderr_logfile=/var/www/cabinet_titl_usr/data/www/cabinet.titlo.ru/storage/logs/supervisor-cluster-child.log
stdout_logfile_maxbytes=20MB
stderr_logfile_maxbytes=20MB

