; sudoers для /admin/supervisor (PHP-FPM = cabinet_titl_usr):
; /etc/sudoers.d/cabinet-titlo-supervisor:
; Defaults:cabinet_titl_usr !requiretty
; cabinet_titl_usr ALL=(root) NOPASSWD: /usr/bin/supervisorctl status, /usr/bin/supervisorctl status *, /usr/bin/supervisorctl start cabinet-titlo-*, /usr/bin/supervisorctl stop cabinet-titlo-*, /usr/bin/supervisorctl restart cabinet-titlo-*
