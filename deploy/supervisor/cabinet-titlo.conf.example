; Supervisor для cabinet.titlo.ru — паритет с lk.redbox.su (54 процесса).
; Отдельный файл, не трогаем конфиги FastPanel/nginx.
;
; Установка / обновление (от root):
;   cp deploy/supervisor/cabinet-titlo.conf.example /etc/supervisor/conf.d/cabinet-titlo.conf
;   supervisorctl reread && supervisorctl update
;
; Управление — /admin/supervisor (роль admin). Порт :9001 наружу не открываем.

; --- shared paths (заменить при другом деплое) ---
; APP=/var/www/cabinet_titl_usr/data/www/cabinet.titlo.ru
; PHP=/opt/php74/bin/php
; USER=cabinet_titl_usr

[program:cabinet-titlo-default]
process_name=%(program_name)s_%(process_num)02d
command=/opt/php74/bin/php /var/www/cabinet_titl_usr/data/www/cabinet.titlo.ru/artisan queue:work database --queue=default,cluster_high,high,medium --sleep=1 --tries=2 --timeout=600
directory=/var/www/cabinet_titl_usr/data/www/cabinet.titlo.ru
user=cabinet_titl_usr
numprocs=6
autostart=true
autorestart=true
stopwaitsecs=660
stdout_logfile=/var/www/cabinet_titl_usr/data/www/cabinet.titlo.ru/storage/logs/supervisor-default.log
stderr_logfile=/var/www/cabinet_titl_usr/data/www/cabinet.titlo.ru/storage/logs/supervisor-default.log
stdout_logfile_maxbytes=20MB
stderr_logfile_maxbytes=20MB

[program:cabinet-titlo-cluster-child]
process_name=%(program_name)s_%(process_num)02d
command=/opt/php74/bin/php /var/www/cabinet_titl_usr/data/www/cabinet.titlo.ru/artisan queue:work database --queue=child_cluster --sleep=1 --tries=2 --timeout=600
directory=/var/www/cabinet_titl_usr/data/www/cabinet.titlo.ru
user=cabinet_titl_usr
numprocs=6
